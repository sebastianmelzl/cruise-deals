{
  "name": "@cruise-deals/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp src/db/schema.sql dist/db/schema.sql",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/db/seed.ts",
    "scrape": "tsx src/scripts/scrape.ts"
  },
  "dependencies": {
    "@cruise-deals/shared": "*",
    "@cruise-deals/scrapers": "*",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pino": "^9.2.0",
    "pino-http": "^10.2.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^11.2.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
