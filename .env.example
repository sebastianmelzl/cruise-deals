# API Server
PORT=3001
NODE_ENV=development

# Database
DB_PATH=./data/cruises.db

# Scraper settings
SCRAPER_CONCURRENCY=2
SCRAPER_DEFAULT_DELAY_MS=2000
SCRAPER_HEADLESS=true

# Optional: screenshot dir for debug
SCREENSHOT_DIR=./data/screenshots

# Optional: HTML snapshot dir for debug
SNAPSHOT_DIR=./data/snapshots

# Frontend dev proxy (Vite uses this)
VITE_API_URL=http://localhost:3001
